---
import LayoutPrincipal from "../layouts/base-layout.astro";
import cArrow from "../assets/icon/circled-arrow.svg";
import imgBuilding from "../assets/img-building.webp";
---

<LayoutPrincipal>
        <section class="servJCI-section">
            <header>
                <h2>
                    Servicios de consultoría para la acreditación Joint
                    Commission International
                </h2>
                <p>
                    Ofrecemos diferentes servicios adaptados a las necesidades
                    de cada centro.
                </p>
                <p>
                    La cartera de propuestas de apoyo se decide en función de
                    las características y situación de cada organización: tipo
                    de centro, acreditación inicial, reacreditación, tipo de
                    estructuras de apoyo interno y otras circunstancias.
                </p>
                <p class="hightlight">
                    Salqualis desarrolla siempre una propuesta singular adaptada
                    a las características y momento de cada establecimiento.
                </p>
            </header>
            <div class="bg-met-swiper">
                <div>
                    <div class="swiper metodology-swiper">
                        <div class="swiper-wrapper">
                            <article class="swiper-slide">
                                <span>01</span>
                                <h3>Formación y entrenamiento al Liderazgo</h3>
                                <p>
                                    Capacitación específica para directivos y
                                    staff profesional en el modelo JCI.
                                </p>
                            </article>

                            <article class="swiper-slide">
                                <span>02</span>
                                <h3>
                                    Auditoría Simulada Inicial (Mock Survey)
                                </h3>
                                <p>
                                    Realizamos un diagnóstico inicial con la
                                    metodología exacta de JCI (trazadores
                                    clínicos y de sistemas) para conocer su
                                    porcentaje de cumplimiento real al inicio
                                    del proceso .
                                </p>
                            </article>

                            <article class="swiper-slide">
                                <span>03</span>
                                <h3>Soporte y Tutoría Personalizada</h3>
                                <p>
                                    Consultoría tutelada hasta la auditoría
                                    final. Ofrecemos tres escenarios de visitas
                                    al establecimiento (Estratégico, Moderado o
                                    Intenso) adaptados a los requerimientos de
                                    su organización.
                                </p>
                            </article>

                            <article class="swiper-slide">
                                <span>04</span>
                                <h3>Auditoría Simulada final (Mock Survey)</h3>
                                <p>
                                    Realizamos una auditoria simulada cerca de
                                    la fecha de la visita de acreditación para
                                    conocer los puntos más débiles y establecer
                                    las medidas correctoras necesarias.
                                </p>
                            </article>

                            <article class="swiper-slide">
                                <span>05</span>
                                <h3>Ensayo de visita auditoria JCI</h3>
                                <p>
                                    Entrenamos al personal y organización para
                                    la gestión del proceso de auditoria con los
                                    roles de cada uno de los profesionales y el
                                    ensayo de la agenda de trazadores y
                                    entrevistas
                                </p>
                            </article>

                            <article class="swiper-slide">
                                <span>06</span>
                                <h3>
                                    Acompañamiento de profesionales del equipo
                                    Salqualis
                                </h3>
                                <p>
                                    durante los días de la consultoría formal de
                                    acreditación.
                                </p>
                            </article>

                            <article class="swiper-slide">
                                <span>07</span>
                                <h3>Sesiones online</h3>
                                <p>
                                    para responder a dudas o comentar avances en
                                    diferentes momentos del proceso, según las
                                    necesidades de cada establecimiento
                                </p>
                            </article>
                        </div>
                    </div>
                    <div class="swiper-button-next"></div>
                    <div class="swiper-button-prev"></div>
                </div>
            </div>
        </section>

        <section class="servOpening-section">
            <header>
                <h2>Preparación para nuevas aperturas de centros</h2>
            </header>
            <article>
                <ul class="list-border">
                    <li>
                        <strong>ORIENTAR</strong> la estructura de los centros a hacia
                        la excelencia desde su inicio:
                        <ul>
                            <li>a. Flujo de pacientes</li>
                            <li>b. Requerimientos ambientales</li>
                            <li>c. Funcionalidad del edificio</li>
                            <li>d. Requisitos de las instalaciones</li>
                            <li>e. Revisión de la ingeniería del edifico</li>
                        </ul>
                    </li>
                    <li>
                        <strong>ASEGURAR</strong> el cumplimiento de requisitos de
                        JCI para el entorno de la asistencia.
                        <p>
                            <a href="/consultoria-web/team" class="btn-primary"
                                >Conoce a nuestro equipo</a>
                        </p>
                    </li>
                </ul>
                <img src={imgBuilding.src} alt="Imagen de un edificio" />
            </article>
        </section>
        <section class="servForm-section">
            <header>
                <h2>Consultoria estrategica y formación de profesionales</h2>
            </header>
            <article>
                <ul>
                    <li>
                        <strong
                            >Definición de plan funcional para los nuevos
                            centros.</strong
                        >
                        <ul class="list-icon">
                            <li>
                                <img src={cArrow.src} /> Desarrollo de planes funcionales
                                completos de establecimientos sanitarios de nueva
                                apertura para su adecuación al entorno: población,
                                situación de servicios de salud en el área, cartera
                                de servicios pendientes de desarrollo en el entorno,
                                infraestructuras necesarias.
                            </li>
                        </ul>
                    </li>
                    <li>
                        <strong
                            >Desarrollo de soluciones para la mejora en la
                            gestión y planificación de establecimientos
                            sanitarios.</strong
                        >
                        <ul class="list-icon">
                            <li>
                                <img src={cArrow.src} /> Apoyo al liderazgo de las
                                organizaciones en los procesos para la consolidación
                                de <strong>nuevos servicios</strong>,
                                establecimiento de estrategias de innovación,
                                crecimiento y mejora de la eficiencia.
                            </li>
                        </ul>
                    </li>
                    <li>
                        <strong>Formación de profesionales</strong> en área de:
                        <ul class="list-icon">
                            <li>
                                <img src={cArrow.src} /> Calidad y seguridad del paciente.
                            </li>
                            <li>
                                <img src={cArrow.src} /> Desarrollo de los requerimientos
                                de calidad en el proceso completo de la medicación
                                en los establecimientos sanitarios.
                            </li>
                            <li>
                                <img src={cArrow.src} /> Formación para el desarrollo
                                e implantación del modelo de farmacia clínica en los
                                hospitales.
                            </li>
                            <li>
                                <img src={cArrow.src} /> Desarrollo de modelos de
                                gestión en los servicios clínicos, desarrollo de comisiones
                                clínica.
                            </li>
                            <li>
                                <img src={cArrow.src} /> Formación para la mejora
                                en la codificación CIE-10 y posicionamiento y análisis
                                de la información obtenida.
                            </li>
                        </ul>
                    </li>
                </ul>
                
            </article>
            <a href="/consultoria-web/team" class="btn-primary">Conoce a nuestro equipo</a>
            
        </section>
        <section class="servCod-section">
            <header><h2>Servicio de codificación clínica</h2></header>
            <article>
                <ul>
                    <li>
                        <strong
                            >Desarrollo e implantación de la codificación
                            clínica según CIE-10 en centros hospitalarios:</strong
                        >
                        <ul class="list-icon">
                            <li>
                                <img src={cArrow.src} /> Servicio de codificación
                                on-line parcial o completo según necesidades del hospital.
                            </li>
                            <li>
                                <img src={cArrow.src} /> Rigurosidad en la codificación
                                para mejorar la complejidad y case-mix del hospital.
                            </li>
                            <li>
                                <img src={cArrow.src} /> Rapidez en la respuesta para
                                facilitar análisis de la información clínica que apoye
                                la toma de decisiones.
                            </li>
                        </ul>
                    </li>
                </ul>
            </article>
            <a href="/consultoria-web/team" class="btn-primary">Conoce a nuestro equipo</a>
        </section>
</LayoutPrincipal>
