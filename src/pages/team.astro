---
import Layout from "../layouts/Layout.astro";
import { team } from "../data/team.js"
---

<Layout title="Equipo">
    <link rel="preload" href="/assets/team/JGarcia.webp" as="image" slot="header" fetchpriority="high"/>

    <section aria-labelledby="titulo-equipo" class="team-section">
        <div>
            <h1 id="titulo-equipo">
                Liderazgo y Experiencia en Gestión Sanitaria
            </h1>
            <div class="team-grid" role="list">
                {
                    team.map((member, key) => (
                        <article class={`team-card img-${key+1} ${member == team[0] ? 'accent' : ''}`} tabindex="0" role="button" aria-haspopup="dialog">

                                    <div class="img-container">
                                        <img src={member.image} alt={member.name} fetchpriority="high" />
                                    </div>
                                    <div class="text-container">
                                        <h2>
                                            <img src={member.icon} alt="" fetchpriority="high" />{member.name}
                                        </h2>
                                        <p>
                                            {member.role}
                                        </p>
                                        {(key === 0) ? (
                                            <p>
                                                {member.description}
                                            </p>
                                        ) : ""
                                        }


                            </div>
                        </article>
                        <div class="modalover" role="dialog" aria-modal="true" aria-label={`Información de ${member.name}`}>
                            <div class="full-info" role="listitem">
                                <button class="close-btn" aria-label="Cerrar ventana">x</button>
                                <div class="member-main-info">
                                    <div class="img-container">
                                        <img src={member.image} alt={member.name} />
                                        </div>
                                         <h2>
                                           {member.name}
                                        </h2>
                                        <p class="role">
                                            <strong>{member.role}</strong>
                                        </p>
                                        <p class="description">
                                            {member.description}
                                        </p>
                                </div>
                                <div class="member-cv">
                                    <div>
                                        <p>TITULACIÓN DESTACADA</p>
                                        <ul>
                                        {member.cvdestacado.map((item) => (
                                            <li>{item}</li>
                                        )
                                        )}
                                        </ul>
                                    </div>
                                <div class="info-consultoria ">
                                    <p>CONSULTORÍA SALQUALIS</p>
                                    <ul class="list-icon">{member.cvconsultoria.map((item) => (
                                        <li>{item}</li>
                                    )
                                    )}</ul>
                                </div>
                                <div>
                                    <p>EXPERIENCIA PROFESIONAL</p>
                                    <ul>{member.cvtrayectoria.map((item) => (
                                        <li>{item}</li>
                                    )
                                    )}</ul>
                                </div>

                                </div>

                            </div>
                        </div>
                    ))
                }
            </div>
        </div>
    </section>
</Layout>

<script>
    let lastFocusedElement: HTMLElement | null = null;

    document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        const teamCard = target.closest(".team-card") as HTMLElement | null;
        const backInfo = target.closest(".full-info");
        const body = document.querySelector("body");

        if(target.classList.contains("close-btn")){
            const activeModal = target.closest(".modalover.active");
            activeModal?.classList.remove("active");
            body?.classList.remove("stop-scroll");
            lastFocusedElement?.focus();
            lastFocusedElement = null;
        }else if (teamCard || backInfo) {
            const modal = teamCard?.nextElementSibling;
            modal?.classList.add("active");
            body?.classList.add("stop-scroll");
            lastFocusedElement = teamCard;
            setTimeout(() => {
                (modal?.querySelector(".close-btn") as HTMLElement | null)?.focus();
            }, 100);
        }else{
            const activeModal = document.querySelector(".modalover.active");
            if (activeModal) {
                activeModal.classList.remove("active");
                body?.classList.remove("stop-scroll");
                lastFocusedElement?.focus();
                lastFocusedElement = null;
            }
        }
    });

    document.addEventListener("keydown", (e) => {
        const body = document.querySelector("body");
        if (e.key === "Tab") {
            const activeModal = document.querySelector(".modalover.active");
            if (!activeModal) return;

            const focusable = activeModal.querySelectorAll<HTMLElement>(
                'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
            );
            const first = focusable[0];
            const last = focusable[focusable.length - 1];

            if (e.shiftKey && document.activeElement === first) {
                e.preventDefault();
                last?.focus();
            } else if (!e.shiftKey && document.activeElement === last) {
                e.preventDefault();
                first?.focus();
            }
        }

        if (e.key === "Escape") {
            const activeModal = document.querySelector(".modalover.active");
            if (activeModal) {
                activeModal.classList.remove("active");
                body?.classList.remove("stop-scroll");
                lastFocusedElement?.focus();
                lastFocusedElement = null;
            }
        }

        if (e.key === "Enter" || e.key === " "){
            const target = e.target as HTMLElement;
            if (target.classList.contains("team-card")){
                target.nextElementSibling?.classList.add('active');
                lastFocusedElement = target;
                body?.classList.add("stop-scroll");
            }
        }
    });
</script>

<style>
body.stop-scroll{
    overflow:hidden;
}

.team-section {
    text-align: center;
    position: relative;

    &:before {
        content: "";
        background-image: url(/assets/bg-team.svg);
        background-size: contain;
        width: 100%;
        height: 100%;
        position: absolute;
        z-index: -1;
    }

    .team-grid {
        gap: 30px;
        margin-bottom: 30px;
        max-width: var(--max-width-main);
        display: grid;
        overflow: visible;
        width: 100%;

        .team-card {
            cursor: pointer;
            background-color: var(--primary-color);
            border-radius: 10px;
            box-shadow: rgb(0 0 0 / 24%) 0px 3px 8px;

            h2 {
                display: flex;
                justify-content: center;
                gap: 5px;
                font-size: 22px;
                margin-bottom: 10px;
                img{
                    display:none;
                }
            }

            &.accent {
                background-color: var(--secondary-color);

                .img-container img{
                    object-position: bottom;
                }

                .text-container{
                    padding: 20px;
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                }
            }
            
            .img-container {
                padding: 40px 40px 0px 40px;
                img{
                    aspect-ratio: 1 / 1.1;
                    object-fit: cover;
                    height: 100%;
                    transition: ease 0.3s filter;
                    object-position: top;
                }
            }

            &.img-3{
                .img-container{
                    img{
                        object-position: center -47px;
                    }
                }
            }

            &.img-8,
            &.img-7{
                .img-container{
                    img{
                        object-position: center;
                    }
                }
            }

            .text-container{
                padding: 0 15px 15px;
                img{
                    width: 25px;
                }

                p{
                    margin-top:5px;
                }
            }
        }
    }

    .modalover{
        visibility:hidden;
        width:0;
        height:0;
        background-color: transparent;
        opacity:0;
        transition: opacity 0.2s ease, visibility 0.3s;
        position: fixed;

        .full-info{
            font-size:16px;
            max-width:0;
            max-height:0;
            flex-direction: column;
            overflow-y: auto;
            background-color: white;
            height: fit-content;
            padding-left: 0;
            display: flex;
            border-radius: 10px;
            margin: 0 auto;
            position:relative;
            box-shadow: 0px 0px 9px 0px #474646;

            .member-main-info{
                justify-content: center;
                display: flex;
                flex-direction: column;
                align-items: center;
                background-color: #e2eaeb;
                gap:15px;
                background-image: url(/assets/bg-team.svg);
                width: auto;
                padding: 30px;
                margin:15px 30px 0px;
                border-radius:10px;
                border-right:none;

                .img-container{
                    height: 40%;
                    img{
                        width:100%;
                        /* height:100%; */
                        object-fit: cover;
                        max-width:350px;
                        aspect-ratio: 1 / 1.3;
                    }
                }

                h2 {
                    font-size: 22px;
                    margin:0;
                }

                p{
                    margin:0;
                }
            }

            .member-cv{
                text-align: left;
                margin:0;
                width:auto;
                overflow-x: visible;
                padding:20px;

                .info-consultoria{
                    background-color: #c7d6d885;
                    padding: 15px 30px;
                    border-radius: 5px;
                }

                p{
                    font-weight:600;
                }

                ul:not(.list-icon){
                    margin-left: 20px;
                    li{
                        list-style: disc;
                    }
                }
            }

            .close-btn{
                display: flex;
                justify-content: center;
                align-items: center;
                border-radius: 50px;
                position: sticky;
                background-color: var(--secondary-color);
                min-width: 45px;
                min-height: 45px;
                width: 30px;
                height: 30px;
                left: 8px;
                top:8px;
                &:hover{
                    opacity:0.8;
                }
            }
        }

        &.active{
        display: flex;
        width: 100%;
        height: calc(100dvh - 80px);
        top: 0;
        left: 0;
        background-color: #00000080;
        align-items: center;
        margin-top:80px;
        z-index:100;
        opacity:1;
        visibility:visible;

        .full-info{
            
            max-height:95%;
            max-width:95%;
            transition: ease 0.5s max-width, ease 0.5s max-height;
        }
        }
    }
}

@media(min-width:475px){
    .team-section {
        .team-grid {
            grid-template-columns: repeat(2, minmax(200px, 1fr));
            gap:15px;
            /* grid-auto-rows: 1fr; */

            .team-card{
                .img-container{
                    padding: 20px 20px 0px;
                }
            }

            .team-card.accent {
                display: flex;
                grid-column: 1 / 3;

                .img-container{
                    width:50%;
                    padding: 15px 0px 15px 15px;

                }

                .text-container{
                    width:50%;
                    padding: 0px 20px 20px 20px;
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                }
            }
        }
    }
}

@media(min-width:576px){
    .team-section{
        .modalover.active{
            .full-info{
                max-width:90%;
            }
        }
    }

}

@media(min-width:768px){
    .team-section{
        .team-grid{
            max-width: 800px;

            .team-card {
                h2{
                    img{
                        display:flex;
                    }
                }
            }
        }

        .modalover{
            .full-info{
                flex-direction:row;
                padding:0;

                .member-cv{
                    margin: 20px 20px 20px 0px;
                    overflow-y:auto;
                    width: 50%;
                }

                .member-main-info {
                    width: 50%;
                    border-right: 1px solid #2e656933;
                    margin:0;
                    padding:20px;
                    border-top-right-radius: 0px;
                    border-bottom-right-radius: 0px;
                    .description{
                        max-width: 380px;
                    }
                }

                .close-btn{
                    position: absolute;
                    left: 15px;
                    top: 10px;
                    cursor: pointer;
                    background-color: white;
                    /* box-shadow: 0px 0px 3px 0px #bfbfbf; */
                
                }
            }
            &.active{
                .full-info{
                    max-width:97%;
                    max-height:97%;
                }
            }
        }
    }
}

@media(min-width:991px){
    .team-section{
        .modalover.active {
            .full-info{
                max-width: 85%;
            }
        }
    }
}


@media(min-width:1200px){
    .team-section{
        .team-grid{
            max-width:1100px;
            grid-template-columns: repeat(3, minmax(300px, 1fr));
            .team-card{
                img{
                    filter: grayscale(0.5);

                    &:hover{
                    filter:none;
                    }
                }
            }

            .modalover{
                .full-info{
                    .member-main-info{
                        width:40%;
                    }
                }

                .member-cv{
                    width:60%;
                }
            }
        }
    }
}

@media(min-width:1400px){
    .modalover.active .full-info{
        max-width: 65%;
    }
}
</style>
