---
import { ClientRouter } from "astro:transitions";

interface Props {
  title: string;
  description?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://consultoriasalqualis.cl");

const { title,
        description = "En Consultoría Salqualis somos especialistas en acreditación sanitaria JCI (Joint Commision International) y gestión de Calidad. Ayudamos a tu centro sanitario a lograr la excelencia operativa"
                } = Astro.props;
const siteName = "Consultoría Salqualis";
---

<!doctype html>
<html lang="es">
    <head>
        <!-- //Pasarlas como props?? -->
        <meta charset="UTF-8" />
        <title>
            {title} | {siteName}
        </title>
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "WebSite",
                "name": "Consultoría Salqualis",
                "alternateName": ["Salqualis"],
                "url": "https://consultoriasalqualis.cl/"
            }
        </script>
        <meta name="description" content={description}/>
        <meta name="apple-mobile-web-app-title" content="Consultoría Salqualis" />
        <link rel="canonical" href={canonicalURL} />
        <meta name="application-name" content="Consultoría Salqualis" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="robots" content="index, follow" />
        <meta name="google-site-verification" content="AUsQW3Mc0_TQYN431lsKAHBPfNvNHhcNUEUTLrrbefQ" />
        <slot name="header" />

        <link rel="stylesheet" href="/styles/base.css?v=1.5" />

        <!-- FAVICON -->
        <link
            rel="icon"
            type="image/png"
            href="/favicon/favicon-96x96.png"
            sizes="96x96"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
        <link rel="shortcut icon" href="/favicon/favicon.ico" />
        <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png"/>
        <link rel="manifest" href="/favicon/site.webmanifest" />

        <!-- Open Graph / LinkedIn / WhatsApp / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://consultoriasalqualis.cl/"
        />
        <meta property="og:title" content="Consultoría Salqualis | Expertos en Calidad y Acreditación Sanitaria JCI" />
        <meta property="og:description" content="Especialistas en procesos de acreditación JCI y optimización de calidad para centros sanitarios. Logra la excelencia operativa con Salqualis."
        />
        <meta property="og:image" content="/favicon/og-image.png" />
        <meta property="og:site_name" content="Consultoría Salqualis" />
        <meta property="og:locale" content="es_ES" />

        <!-- FUENTE -->
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap"
            rel="stylesheet"
        />
        <ClientRouter />
    </head>
    <body>
        <header>
            <nav class="nav-bar" aria-label="Barra de navegación principal">
                <a
                    href="/"
                    class="logo-img-desktop"
                    aria-label="Volver a Inicio"
                    ><img
                        src="/assets/logo-big.svg"
                        alt="Logo Consultoría Salqualis"
                        fetchpriority="high"
                    /></a
                >

                <a href="/" class="logo-img-mobile" aria-label="Volver a inicio"
                    ><img
                        src="/favicon/favicon.svg"
                        alt="Logo Consultoría Salqualis"
                        fetchpriority="high"
                    /></a
                >
                <label for="burguer-menu" class="burger-label" aria-label="Abrir menú de navegación"
                    ><img
                        src="/assets/icon/burger-menu.svg"
                        alt=""
                        aria-hidden="true"
                        fetchpriority="high"
                    /></label
                >
                <input type="checkbox" id="burguer-menu" />
                <ul>
                    <li>
                        <a class="nav-link active" href="/">Inicio</a>
                    </li>
                    <li>
                        <a class="nav-link" href="/services/">Servicios</a>
                    </li>
                    <li>
                        <a class="nav-link" href="/team/">El Equipo</a>
                    </li>
                    <li>
                        <a class="nav-link" href="/contact/">Contacto</a>
                    </li>
                </ul>
            </nav>
        </header>

        <main>
            <slot />
        </main>

        <footer>
            <div class="footer-top">
                <a href="/" aria-label="Volver a inicio"
                    ><img
                        src="/favicon/favicon.svg"
                        alt="Logo Consultoría Salqualis"
                    /></a
                >

                <div>
                    <nav>
                        <ul>
                            <li>
                                <a href="/">Inicio</a>
                            </li>
                            <li>
                                <a href="/JCIAccreditation/">¿Qué es JCI?</a>
                            </li>
                            <li>
                                <a href="/team/">Nuestro Equipo Experto</a>
                            </li>
                            <li>
                                <a href="/services/"
                                    >Servicios de Acreditación</a
                                >
                            </li>
                            <li>
                                <a href="/#centros-acred">Centros Acreditados</a
                                >
                            </li>
                        </ul>
                    </nav>
                </div>
                <div class="contact-details">
                    <strong>Contacto:</strong>
                    <ul>
                        <li>
                            <a href="mailto:consultoriasalqualis@gmail.com"
                                >consultoriasalqualis@gmail.com</a
                            >
                        </li>
                        <li><a href="tel:+34672485403">+34 672 48 54 03</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-content">
                <div>
                    <p>
                        Consultoría Especializada en seguridad del paciente y
                        excelencia operativa bajo estándares internacionales
                        JCI.
                        <br />
                        Salqualis es una consultora independiente. Joint Commission
                        International® y el Gold Seal of Approval® son marcas registradas
                        propiedad de Joint Commission Resources, Inc.
                    </p>
                </div>
                <p>
                    © 2026 Consultoria Salqualis SL. Todos los derechos
                    reservados. | <a href="/privacy/">Política de Privacidad</a> |
                    <a href="/legal">Aviso Legal</a> | Consultoría para Acreditación
                    de Salud en Chile y España.
                </p>
            </div>
        </footer>

        <style is:global>
            :root {
                --nav-bg: #eeeeeef7;
                --shadow-light: #bcbbbb;
                --border-light: #ccc;
                --z-header: 1000;
            }

            body>header {
                background: var(--nav-bg);
                position: fixed;
                top: 0;
                width: 100%;
                z-index: var(--z-header);
                padding: 10px;
                box-shadow: 0px 1px 4px var(--shadow-light);

                nav {
                    display: flex;
                    width: 100%;
                    justify-content: space-between;
                    align-items: center;
                    flex-direction: row-reverse;

                    .logo-img-desktop {
                        display: none;
                    }

                    .logo-img-mobile {
                        display: flex;
                        margin-right: 20px;
                        width: 62px;
                        height: 62px;
                    }

                    #burguer-menu {
                        display: none;
                    }

                    .burger-label {
                        display: block;
                        cursor: pointer;
                        transition: ease .5s;
                        width: 40px;
                        height: 40px;

                        &.turnRound {
                            transform: rotate(90deg);
                        }
                    }

                    ul {
                        flex-direction: column;
                        position: absolute;
                        top: 60px;
                        background-color: var(--nav-bg);
                        width: 100vw;
                        left: 0;
                        padding: 60px 0 0 0;
                        gap: 35px;
                        display: none;
                        height: 100dvh;
                        align-items: center;
                        justify-content: flex-start;
                        list-style: none;
                        font-size: 18px;

                        li a {
                            color: black;
                            font-weight: 400;

                            &.active {
                                font-weight: 700;
                                color: var(--color-dark);
                            }
                        }
                    }

                    input:checked + ul {
                        display: flex;
                    }
                }
            }

            footer {
                padding: 15px 20px;
                text-align: center;
                border-top: 1px solid var(--border-light);
                font-size: 12px;
                justify-content: space-around;
                display: flex;
                flex-direction: column;
                align-items: center;

                >* {
                    max-width: var(--max-width-main);
                }

                .footer-top {
                    width: 100%;
                    align-items: center;
                    text-align: center;
                    gap: 20px;
                    display: grid;
                    grid-template-columns: 150px 1fr;
                    grid-template-rows: 1fr 100px;

                    .contact-details {
                        text-align: left;
                    }
                }

                .footer-content {
                    display: flex;
                    flex-direction: column;
                    justify-content: center;
                    font-size: 10px;

                    div:first-child {
                        display: flex;
                        flex-direction: column;

                        img {
                            width: 60px;
                            height: 60px;
                        }
                    }

                    p:nth-child(2) {
                        column-count: 2;

                        ul {
                            margin-top: 0
                        }
                    }
                }

                ul {
                    gap: 10px;
                    display: flex;
                    flex-direction: column;
                }
            }

            @media (min-width: 575px) {
                footer .footer-top {
                    display: flex;
                    justify-content: space-between;
                    text-align: left;
                    align-items: center;
                }
            }

            @media (min-width: 992px) {
                body>header nav {
                    height: 60px;
                    flex-direction: row;
                    justify-content: center;

                    .logo-img-desktop {
                        display: block;
                        max-width: 200px;
                        margin-left: 20px;
                        position: absolute;
                        top: 2px;
                        left: -7px;
                    }

                    .logo-img-mobile {
                        display: none;
                    }

                    #burguer-menu,
                    .burger-label {
                        display: none;
                    }

                    ul {
                        display: flex;
                        flex-direction: row;
                        position: static;
                        background: none;
                        width: auto;
                        height: auto;
                        padding: 0;
                        gap: 50px;
                        justify-content: center;
                        align-items: center;
                        font-size: inherit;
                        list-style: none;
                    }
                }
            }
        </style>

        <script>
            //burger menu
            document.addEventListener("astro:page-load", () => {
                const burgerLabel = document.querySelector(".burger-label");
                const burgerInput = document.getElementById("burguer-menu");

                burgerInput?.addEventListener("click", (e) => {
                    console.log(e.target);
                    if (!burgerLabel?.classList.contains("turnRound")) {
                        burgerLabel?.classList.add("turnRound");
                        console.log("añadido turnround");
                    } else {
                        burgerLabel?.classList.remove("turnRound");
                        console.log("eliminada turnround");
                    }
                });
            });

            //nav-link active
            document.addEventListener("astro:page-load", () => {
                const currentPage = window.location.pathname;
                console.log(currentPage);

                const navLinksPath = document.querySelectorAll(".nav-link");

                navLinksPath.forEach((link) => {
                    const linkPath = link.getAttribute("href");
                    console.log("LinkPath:", linkPath);

                    link.classList.remove("active");

                    if (linkPath === currentPage) {
                        link.classList.add("active");
                    }

                    console.log("CurrentPage;", currentPage);
                });
            });
        </script>
    </body>
</html>
